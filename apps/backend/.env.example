# Copy to `.env` and fill every value. Do not commit real secrets.
# Required for the API to start:
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/reviewqr_pro
JWT_SECRET=use-a-long-random-string-here
JWT_EXPIRES_IN=7d
COOKIE_EXPIRY=7
FRONTEND_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=choose-a-strong-password

# AI review suggestions (pick one). If neither key is set, static fallbacks are used.
# Free tier: https://console.groq.com — create an API key (recommended).
GROQ_API_KEY=
# Optional; default in code is llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional paid alternative:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: IANA timezone for daily scan charts (e.g. Asia/Kolkata). Omit to use server default / UTC fallback.
# ANALYTICS_TIMEZONE=
